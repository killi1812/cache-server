# --- Virtual Host 1: localhost / IP ---
192.168.1.113, localhost, test.cache-server.francvok.from.hr {
    # Caddy automatically redirects HTTP (80) to HTTPS (443) 
    # and manages local certificates for localhost and IP.
    # tls internal

    @special_paths {
        path /ws* /api/v1/deploy/log/*
    }

    # Proxy for the special paths (WebSockets & Logs)
    reverse_proxy @special_paths cache-server:54321 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up Connection "Upgrade"
        header_up Upgrade "websocket"
        
        transport http {
            read_timeout 36000s
            write_timeout 36000s
        }
    }

    # Proxy everything else to the main app
    reverse_proxy cache-server:12345 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}

        transport http {
            read_timeout 36000s
            write_timeout 36000s
        }
    }
}

# --- Virtual Host 2: test.localhost / test.192.168.1.113 ---
test.192.168.1.113, test.localhost, test.192.168.1.113.nip.io, test.cache-server.francvok.from.hr {
    # Also handles automatic HTTPS via internal CA
    # tls internal

    reverse_proxy cache-test-node:23455 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}

        transport http {
            read_timeout 36000s
            write_timeout 36000s
        }
    }
}
