{
    "swagger": "2.0",
    "info": {
        "description": "API for nix binary cache interactions (narinfo, nar, etc).",
        "title": "Binary Cache API",
        "contact": {},
        "version": "1.0"
    },
    "basePath": "/",
    "paths": {
        "/nar/{filename}": {
            "get": {
                "description": "Download a NAR file from the cache.",
                "produces": [
                    "application/octet-stream"
                ],
                "tags": [
                    "binary-cache"
                ],
                "summary": "Download NAR file",
                "parameters": [
                    {
                        "type": "string",
                        "description": "NAR filename (with or without .nar extension)",
                        "name": "filename",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "file"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/model.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/nix-cache-info": {
            "get": {
                "description": "Get information about the nix store configuration.",
                "produces": [
                    "text/plain"
                ],
                "tags": [
                    "binary-cache"
                ],
                "summary": "Get nix-cache-info",
                "responses": {
                    "200": {
                        "description": "StoreDir: /nix/store...",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/{narUuid}": {
            "put": {
                "description": "Upload raw NAR data for a given UUID.",
                "consumes": [
                    "application/octet-stream"
                ],
                "tags": [
                    "binary-cache"
                ],
                "summary": "Upload NAR data",
                "parameters": [
                    {
                        "type": "string",
                        "description": "NAR UUID",
                        "name": "narUuid",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created"
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/model.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/model.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/{storeHash}": {
            "get": {
                "description": "Get metadata (.narinfo) or file listing (.ls) for a store hash.",
                "produces": [
                    "text/plain",
                    "application/json"
                ],
                "tags": [
                    "binary-cache"
                ],
                "summary": "Get .narinfo or .ls",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Store hash with extension (.narinfo or .ls)",
                        "name": "storeHash",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "ls json",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/model.ErrorResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "model.ErrorResponse": {
            "type": "object",
            "properties": {
                "additional_info": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "error": {
                    "type": "string",
                    "example": "not found"
                }
            }
        }
    }
}